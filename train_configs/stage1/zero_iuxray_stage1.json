{   "zero_allow_untested_optimizer": true,
    "zero_optimization": {
        "stage": 1,
        "contiguous_gradients": true,
        "reduce_bucket_size": 5e7,
        "allgather_bucket_size": 5e7
    },
    "optimizer": {
        "type": "AdamW",
        "params": {
            "lr": 1e-3,
            "betas": [0.9, 0.999],
            "eps": 1e-8,
            "weight_decay": 0.0001
        }
    },
    "fp16": {
        "enabled": true,
        "loss_scale": 0,
        "loss_scale_window": 1000,
        "initial_scale_power": 12,
        "hysteresis": 2,
        "min_loss_scale": 1
    },
    "scheduler": {
        "type": "WarmupCosineLR",
        "params": {
                "warmup_min_ratio": 0,
                "warmup_num_steps": 13,
                "total_num_steps": 192,
                "warmup_type": "linear",
                "cos_min_ratio": 1.0
        }
    },
    "train_batch_size": 32,
    "train_micro_batch_size_per_gpu": 8,
    "gradient_clipping": 1.0
}
